  special bond factors lj:    0        0        0       
  special bond factors coul:  0        0        0       
     2 = max # of 1-2 neighbors
     1 = max # of 1-3 neighbors
     1 = max # of 1-4 neighbors
     2 = max # of special neighbors
  special bonds CPU = 0.004 seconds
  read_data CPU = 0.158 seconds

print "Initial configuration loaded."
Initial configuration loaded.
reset_timestep 0
print "Applying shear rate: ${gamma}"
Applying shear rate: 5e-6
change_box all triclinic
Changing box ...
  triclinic box = (-25 -25 -25) to (25 25 25) with tilt (0 0 0)
kspace_style pppm/tip4p 1.0e-5

pair_coeff 1 1 0.21084 3.1668 #O-O
pair_coeff * 2 0.0 1.0

bond_coeff 1 0.9572 #O-H
angle_coeff 1 104.52 #H-O-H

group gH2O type 1 2
12288 atoms in group gH2O
group gO type 1
4096 atoms in group gO

neighbor 3.0 bin
neigh_modify delay 0 every 1 check yes

timestep 1.0
fix 1 gH2O shake 1.0e-4 100 10000 b 1 a 1
Finding SHAKE clusters ...
       0 = # of size 2 clusters
       0 = # of size 3 clusters
       0 = # of size 4 clusters
    4096 = # of frozen angles
  find clusters CPU = 0.004 seconds

# # 系统弛豫到平衡态
# fix fnvt_equil all nvt temp ${T} ${T} 100.0
# thermo 1000
# thermo_style custom step temp etotal pe
# thermo_modify flush yes
# run 100000 # 100 ps
# unfix fnvt_equil

# 系统剪切变形
variable shear_rate equal ${gamma}
variable shear_rate equal 5e-6
variable v_lo equal -0.5*ly*v_shear_rate
variable v_hi equal  0.5*ly*v_shear_rate
variable ylo equal -0.5*ly
variable yhi equal  0.5*ly

velocity all ramp vx ${v_lo} ${v_hi} y ${ylo} ${yhi} sum yes units box
velocity all ramp vx -0.000125 ${v_hi} y ${ylo} ${yhi} sum yes units box
velocity all ramp vx -0.000125 0.000125 y ${ylo} ${yhi} sum yes units box
velocity all ramp vx -0.000125 0.000125 y -25 ${yhi} sum yes units box
velocity all ramp vx -0.000125 0.000125 y -25 25 sum yes units box

print "Velocity ramp from y=${ylo} to y=${yhi}"
Velocity ramp from y=-25 to y=25

fix fdeform all deform 1 xy erate ${gamma} remap v
fix fdeform all deform 1 xy erate 5e-6 remap v
fix fnvt all nvt/sllod temp ${T} ${T} 100.0
fix fnvt all nvt/sllod temp 225 ${T} 100.0
fix fnvt all nvt/sllod temp 225 225 100.0

# ------- 加入动量修正项 -------
fix mom_shear all momentum 100 linear 1 1 1 angular

compute tilt all temp/deform
compute 	        layers all chunk/atom bin/1d y center 0.05 units reduced
fix 		        layers_vx all ave/chunk 20 250 5000 layers vx file profile_vx_${gamma}.txt
fix 		        layers_vx all ave/chunk 20 250 5000 layers vx file profile_vx_5e-6.txt
variable L0_x equal lx
variable L0_y equal ly
variable L0_z equal lz

compute p all pressure NULL virial
variable sxy equal -c_p[4] * 1.01325e-4  # convert to GPa


variable dt equal 1.0e-15
variable gammaSI equal ${gamma}*1e15
variable gammaSI equal 5e-6*1e15

variable massAll equal mass(all)/6.022e23
variable volCm3 equal vol*1.0e-24
variable density_sys equal v_massAll/v_volCm3
variable tau_pa equal v_sxy * 1e9
variable gamma_s equal ${gamma} * 1e15
variable gamma_s equal 5e-6 * 1e15
variable viscosity equal v_tau_pa / v_gamma_s

variable strain equal step*${gammaSI}*${dt}
variable strain equal step*5000000000*${dt}
variable strain equal step*5000000000*1e-15

thermo 100
thermo_style custom step temp etotal pe pxy v_sxy v_strain v_viscosity
thermo_modify flush yes


# ---------为低速剪切设置输出轨迹文件---------
# ----- set PPPM reset loop -----
variable strain_reset equal 0.01 # 1% strain reset
variable stepsPerReset equal ceil(${strain_reset}/(${gammaSI}*${dt}))
variable stepsPerReset equal ceil(0.01/(${gammaSI}*${dt}))
variable stepsPerReset equal ceil(0.01/(5000000000*${dt}))
variable stepsPerReset equal ceil(0.01/(5000000000*1e-15))

print "Steps per PPPM reset: ${stepsPerReset}"
Steps per PPPM reset: 2000

variable total_steps equal ceil(${Tpre}/${stepsPerReset})
variable total_steps equal ceil(200000/${stepsPerReset})
variable total_steps equal ceil(200000/2000)
print "Total steps: ${Tpre}"
Total steps: 200000

variable nloop loop ${total_steps}
variable nloop loop 100
label loop_start
run ${stepsPerReset}
run 2000
